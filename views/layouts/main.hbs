<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/cards.css">
    <script defer src="{{jsFile}}"></script>
    <title>{{title}}</title>
</head>
<body>
    <div class="hero-container">
        <div class="hero-image" role="img" aria-label="{{heroLabel}}" style="background-image: url('{{heroImage}}'); background-position: {{heroImagePosition}};"></div>
        <div class="hero-text">
            <h1>{{heroTitle}}</h1>
            <p>{{heroSmallText}}</p>
        </div>
        {{> navbar }}
    </div>

    {{{body}}}

    {{> footer }}
</body>
</html>